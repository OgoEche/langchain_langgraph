from dotenv import load_dotenv
from langchain.agents import create_agent
from langchain.tools import tool
from langchain_core.messages import HumanMessage
from langchain_openai import ChatOpenAI
from tavily import TavilyClient
from langchain_tavily import TavilySearch

load_dotenv(override=True)

tavily = TavilyClient()

@tool
def search(query: str) -> str:
    """
    Tool that searches over the internet
    Args:
        query: The query to search for.
    Returns:
        The search result.
    """
    print(f'Searching for {query}')
    return tavily.search(query=query)


def getAgent():
    #define llm, tools and agent
    llm = ChatOpenAI()
    #tools = [search]
    tools = [TavilySearch()]
    agent = create_agent(model=llm, tools=tools)
    return agent


def main():
    print("Demo: Search Agent using Langchain ecosystems")

    #call agent with request
    result = getAgent().invoke({'messages':HumanMessage(content="search for 10 job postings for an AI engineer using Langcahin, CrewAI, Google ADK in London on linkedin and list the details")})
    print(result)

    
if __name__ == "__main__":
    main()